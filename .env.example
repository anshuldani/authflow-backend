# AuthFlow Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# LLM Keys — get from aistudio.google.com (free) + platform.openai.com
GOOGLE_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here_optional_fallback

# ChromaDB path — relative to authflow-backend/
CHROMA_DB_PATH=./data/chroma_db

# Demo mode — set to 1 to use hardcoded responses without LLM call
# USE THIS IF API IS DOWN DURING DEMO
DEMO_MODE=0
