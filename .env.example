# AuthFlow Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# LLM Keys
GOOGLE_API_KEY=your_gemini_api_key_here         # aistudio.google.com (free tier available)
OPENAI_API_KEY=your_openai_api_key_here          # Optional fallback (platform.openai.com)

# ChromaDB path — relative to authflow-backend/
CHROMA_DB_PATH=./data/chroma_db

# Demo mode — set to 1 to use hardcoded responses without LLM call
# USE THIS IF API IS DOWN DURING DEMO
DEMO_MODE=0

# Supabase JWT secret — from Supabase dashboard → Settings → API → JWT Secret
# Required for production JWT verification on /generate-pa, /generate-appeal, /extract-note
# If not set, JWT verification is bypassed (dev only)
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Deployment (Railway / Cloud Run)
PORT=8001
